# ============================================================================
#  Dendra — testnet miner config.  Copy this file to  .env  then fill it in.
#      cp .env.example .env
# ============================================================================

# --- PUBLIC testnet endpoints (provided by the network operator) ---
#  Ask the operator for them, or get them from the testnet page.
DENDRA_NODE=tcp://RPC_PUBLIC_FILL_ME:26657
DENDRA_RELAY=http://RELAY_PUBLIC_FILL_ME:8645
FAUCET=http://FAUCET_PUBLIC_FILL_ME:4500

# --- PINNED model served by the network (must match the on-chain registry) ---
#  This is THE model that will be downloaded LOCALLY on your machine and served by your GPU.
DENDRA_MODEL_ID=llama3.1:8b-instruct-q4_K_M

# --- VERIFICATION embedder: REAL SEMANTIC (not the lexical bag-of-words) ---
#  On-chain verification compares embeddings. In "backend" mode, the miner embeds via Ollama (/api/embeddings)
#  with a DEDICATED embedding model -> we measure MEANING, not just shared words. All miners in a
#  committee must use the SAME one (keep these values).
DENDRA_EMBED_MODE=backend
DENDRA_EMBED_API_MODEL=nomic-embed-text

# --- YOUR miner's identity (unique on the network; keep it stable) ---
MINER_ID=m-change-me
