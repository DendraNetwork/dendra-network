# Dendra — PUBLIC LAUNCH .env (template).
# Do NOT fill this file inside the repo: run `deploy/launch/launch_env_check.sh --init`, which generates
# ~/.dendra-launch.env (OUTSIDE the repo) with strong secrets. This template documents the knobs.
#
# The code's fail-closed guards REFUSE TO BOOT if these are missing under DENDRA_PUBLIC=1:
#   gateway : empty/weak/default key   -> refuse
#   relay   : missing / <16-char token -> refuse
#   faucet  : PoW <= 0                  -> refuse

# --- Exposure switch (arms ALL fail-closed guards) ---
DENDRA_PUBLIC=1

# --- Secrets (generated by --init; NEVER committed) ---
DENDRA_API_KEY=__GENERATED_BY_INIT__
DENDRA_RELAY_TOKEN=__GENERATED_BY_INIT__

# --- Faucet anti-Sybil (>= 18 bits; 20 = ~1 s of client compute, Sybil drain priced out) ---
DENDRA_FAUCET_POW_BITS=20
DENDRA_FAUCET_IP_DAILY=5
DENDRA_FAUCET_ADDR_COOLDOWN=86400
DENDRA_FAUCET_DAILY_CAP=2000

# --- Chat front-end (accounts required in public) ---
WEBUI_AUTH=True

# --- Audit / judge ---
DENDRA_AUDIT_SAMPLE_BPS=5000
# Audit resolution timeout: > p95 of the REAL 5th verdict (calibrate on day one).
DENDRA_AUDIT_RESOLVE_TIMEOUT=240
DENDRA_JUDGE_ABSTAIN_VOTE=1
# Availability-slash stays DORMANT until proven false-positive-free in the real world (never 1 at launch).
DENDRA_AVAIL_SLASH=0

# --- Moderation ---
# The ONLY content filter is a deterministic in-process regex floor (incl. the CSAM pattern), always on.
# The optional LLM classifier stage (llama-guard) is OFF here because DENDRA_GUARD_MODEL is unset, and this
# file deliberately leaves it unset. It is available, not unreachable: content_filter.py reads that variable
# and arms the stage when it is set. Posture = research/testnet, NOT a legal-compliance guarantee.

# --- Points ratio (exclude subsidy addresses from the numerator and the USE bucket) ---
DENDRA_R2_EXCLUDE_ADDRS=

# --- Public facades (The Proof / points, compose profile `public`) ---
DENDRA_PROOF_CORS=https://dendranetwork.com
DENDRA_POINTS_CORS=https://dendranetwork.com

# --- HTTPS front (Caddy reverse proxy: api. / chat. / proof.dendranetwork.com) ---
# Gateway CORS: let the site's in-page chat (browser, https://dendranetwork.com) call the gateway cross-origin.
DENDRA_CORS_ORIGIN=https://dendranetwork.com
# Open WebUI public URL behind Caddy (correct absolute links / auth).
WEBUI_URL=https://chat.dendranetwork.com
