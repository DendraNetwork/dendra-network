# ============================================================================
#  Dendra — testnet node config.  Copy this file to  .env  then fill it in.
#      cp .env.example .env
# ============================================================================

# --- Network (provided by the operator / the testnet page) ---
CHAIN_ID=dendra
MONIKER=my-dendra-node

# URL of the PUBLIC genesis.json (frozen by the operator)
GENESIS_URL=https://FILL_ME/genesis.json

# EXPECTED genesis sha256 (given in network-info.txt) -> anti-MITM check MANDATORY (the node REFUSES to
# start if empty). TRUSTED network only: set DENDRA_ALLOW_UNVERIFIED_GENESIS=1 to skip the check.
GENESIS_SHA256=FILL_ME_sha256

# Public seeds: "<node_id>@<host>:26656" (multiple, comma-separated)
SEEDS=NODEID_FILL_ME@SEED_HOST:26656

# Persistent peers (optional): same format as SEEDS
PERSISTENT_PEERS=
